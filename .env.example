# ============================================================
# AI Meeting Assistant — environment template
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# --- Database: Supabase Postgres (REQUIRED) ------------------
# Use the SESSION POOLER host (IPv4). The direct host
# db.<project-ref>.supabase.co is IPv6-only and unreachable from
# Docker / Railway / most container platforms.
# Pooler user format: postgres.<project-ref>
# Special characters in the password are URL-encoded automatically.
DB_USER=postgres.your-project-ref
DB_PASSWORD=your-supabase-db-password
DB_NAME=postgres
DB_HOST=aws-0-<region>.pooler.supabase.com
DB_PORT=5432

# --- Supabase Auth (REQUIRED in production) ------------------
# User credentials are stored/verified by Supabase Auth (GoTrue).
# Project URL + anon (publishable legacy) key: Supabase dashboard
# → Settings → API. If unset, the backend falls back to local
# bcrypt hashes in the users table (dev/tests only).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# Google sign-in additionally requires (one-time, Supabase dashboard):
#   1. Authentication → Sign In / Providers → Google → enable, paste a
#      Google OAuth Client ID + Secret (console.cloud.google.com →
#      Credentials → OAuth client, authorized redirect URI =
#      https://<project-ref>.supabase.co/auth/v1/callback).
#   2. Authentication → URL Configuration → add the frontend callback
#      (e.g. https://your-frontend.vercel.app/auth/callback and
#      http://localhost:3000/auth/callback) to Redirect URLs.

# --- CORS ----------------------------------------------------
# Extra allowed browser origins, comma-separated (e.g. a custom
# frontend domain). *.vercel.app deployments of this project are
# always allowed via a built-in regex; localhost is always allowed.
ALLOWED_ORIGINS=

# --- JWT Authentication (REQUIRED) ---------------------------
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-64-hex-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Redis / Celery ------------------------------------------
# docker compose: the redis service name resolves automatically.
# Railway: paste the managed Redis connection URL instead.
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Speech-to-text + LLM: Groq (REQUIRED) -------------------
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key
LLM_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER=groq
# Set to 'true' only for offline testing without a valid API key
USE_MOCK_TRANSCRIPTION=false

# --- Speaker diarization: pyannote via Hugging Face ----------
# The token must have ACCEPTED the model conditions for
# pyannote/speaker-diarization-3.1 AND pyannote/segmentation-3.0
# on their Hugging Face pages, or loading fails with a 401.
HF_TOKEN=hf_your_huggingface_token
HUGGINGFACE_TOKEN=hf_your_huggingface_token
DEVICE=cpu

# --- AWS S3 (optional — falls back to local disk) ------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=ai-meeting-bucket
S3_ENDPOINT_URL=

# --- Frontend (set on VERCEL, not on the backend host) -------
# The deployed backend URL, e.g. https://your-app.up.railway.app
# The frontend derives the wss:// WebSocket URL from this.
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Misc ----------------------------------------------------
DEBUG=False
