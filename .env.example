# Environment Variables for AI Meeting Intelligence Platform

# ============================================
# Database Configuration (REQUIRED)
# ============================================
# PostgreSQL database credentials
# Note: Special characters in password will be automatically URL-encoded
DB_USER=aiuser
DB_PASSWORD=your_secure_password_here
DB_NAME=ai_meeting
DB_HOST=localhost  # Use 'postgres' when running in Docker
DB_PORT=5432       # Use 5432 for Docker, 5433 for local if needed

# ============================================
# JWT Authentication (REQUIRED)
# ============================================
# Generate a secure secret key using: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# Redis Configuration
# ============================================
# Redis for caching and Celery broker
REDIS_URL=redis://localhost:6379/0  # Use 'redis://redis:6379/0' in Docker
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============================================
# AWS S3 Configuration (REQUIRED for file storage)
# ============================================
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=ai-meeting-bucket
S3_ENDPOINT_URL=  # Leave empty for AWS, or set for S3-compatible services

# ============================================
# Whisper Settings (Speech-to-Text)
# ============================================
# Model options: tiny, base, small, medium, large
# Larger models are more accurate but slower
WHISPER_MODEL=base
DEVICE=cpu  # Use 'cuda' if you have GPU support

# ============================================
# LLM Settings (AI Summaries)
# ============================================
# Groq API key from Groq Console (https://console.groq.com)
# Get your API key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER=groq  # Options: groq, gemini, mistral, llama

# ============================================
# Frontend Configuration
# ============================================
# Backend API URL for frontend to connect to
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================
# Debug Mode
# ============================================
# Set to True for development, False for production
DEBUG=False
